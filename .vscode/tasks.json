{
  // VS Code tasks. Run with Cmd+Shift+P → "Tasks: Run Task"
  // (or bind a shortcut yourself).
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build textbook (latexmk)",
      "type": "shell",
      "command": "latexmk",
      "args": ["-pdf", "main.tex"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Clean build artefacts",
      "type": "shell",
      "command": "latexmk",
      "args": ["-C"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Open compiled PDF",
      "type": "shell",
      "command": "open",
      "args": ["main.pdf"],
      "presentation": {
        "echo": false,
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
